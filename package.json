{
  "name": "@kfarkasHU/atfw",
  "version": "0.1.12",
  "bin": {
    "atfw": "dist/src/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "version:commit": "commit-and-tag-version --skip.tag",
    "prepare": "npm run build",
    "test:jest": "jest --config jest.config.ts --coverage",
    "test:vitest": "vitest --config vitest.config.ts run --coverage"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^3.2.6",
    "commit-and-tag-version": "^12.6.0",
    "eslint": "^9.31.0",
    "jest": "^30.0.5",
    "globals": "^16.3.0",
    "ts-jest": "^29.4.1",
    "typescript-eslint": "^8.38.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "volta": {
    "node": "24.12.0",
    "npm": "11.17.0"
  },
  "dependencies": {
    "ts-morph": "^28.0.0"
  }
}
